<!DOCTYPE html>
<html>
<head>
    <style>
        p { color: blue; }               /* Element */
        #title { color: red; }           /* ID */
        .box { background: yellow; }     /* Class */
        h1, h2 { font-family: Arial; }   /* Group */
        * { margin: 5px; }               /* Universal */
    </style>
</head>
<body>

<h1 id="title">Heading 1</h1>
<h2>Heading 2</h2>
<p class="box">This is a paragraph</p>

</body>
</html>

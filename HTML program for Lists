<!DOCTYPE html>
<html>
<head>
    <title>HTML Lists Example</title>
</head>
<body>

<h2>Ordered List</h2>
<ol>
    <li>Apple</li>
    <li>Banana</li>
    <li>Mango</li>
</ol>

<h2>Unordered List</h2>
<ul>
    <li>Red</li>
    <li>Green</li>
    <li>Blue</li>
</ul>

<h2>Nested List</h2>
<ul>
    <li>Fruits
        <ul>
            <li>Apple</li>
            <li>Orange</li>
        </ul>
    </li>
    <li>Vegetables
        <ul>
            <li>Carrot</li>
            <li>Potato</li>
        </ul>
    </li>
</ul>

<h2>Ordered List inside Unordered List</h2>
<ul>
    <li>Subjects
        <ol>
            <li>Maths</li>
            <li>Science</li>
        </ol>
    </li>
</ul>

<h2>Definition List</h2>
<dl>
    <dt>HTML</dt>
    <dd>Hyper Text Markup Language</dd>

    <dt>CSS</dt>
    <dd>Style sheet language</dd>
</dl>

</body>
</html>

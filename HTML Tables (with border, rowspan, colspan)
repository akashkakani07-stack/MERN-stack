<!DOCTYPE html>
<html>
<head>
    <title>Table Example</title>
</head>
<body>

<h2>Student Table</h2>

<table border="2">
    <tr>
        <th rowspan="2">Name</th>
        <th colspan="2">Marks</th>
    </tr>
    <tr>
        <th>Math</th>
        <th>Science</th>
    </tr>
    <tr>
        <td>Akash</td>
        <td>90</td>
        <td>85</td>
    </tr>
    <tr>
        <td>Rahul</td>
        <td>88</td>
        <td>92</td>
    </tr>
</table>

</body>
</html>
